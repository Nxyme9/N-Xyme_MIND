discover_providers() {
    log "Scanning for VPN provider plugins..."
    local found=0

    for provider_dir in "${PROVIDERS_DIR}"/*/; do
        [[ -d "${provider_dir}" ]] || continue
        local provider_name
        provider_name=$(basename "${provider_dir}")
        local config_file="${provider_dir}/config.json"
        local plugin_file="${provider_dir}/plugin.sh"

        if [[ -f "${config_file}" ]]; then
            vlog "Found provider config: ${provider_name}"
            found=$((found+1))
        fi

        if [[ -f "${plugin_file}" ]]; then
            vlog "Found provider plugin: ${provider_name}"
            chmod +x "${plugin_file}" 2>/dev/null || true
        fi
    done

    # Also check for system-installed provider CLIs
    for provider in mullvad nordvpn protonvpn surfshark wg; do
        if command -v "${provider}" &>/dev/null; then
            vlog "System provider CLI found: ${provider}"
        fi
    done

    ok "Found ${found} provider plugins in ${PROVIDERS_DIR}"
}

source_provider_plugin() {
    local provider_name="${1}"
    local plugin_file="${PROVIDERS_DIR}/${provider_name}/plugin.sh"

    if [[ -f "${plugin_file}" ]]; then
        vlog "Sourcing plugin: ${plugin_file}"
        # shellcheck source=/dev/null
        source "${plugin_file}"
        return 0
    fi
    return 1
}

provider_authenticate() {
    local provider_name="${1}"
    vlog "Authenticating provider: ${provider_name}"

    if source_provider_plugin "${provider_name}"; then
        if declare -f "auth_${provider_name}" &>/dev/null; then
            "auth_${provider_name}"
            return $?
        fi
    fi

    # Fallback: check system CLI
    case "${provider_name}" in
        mullvad)
            if command -v mullvad &>/dev/null; then
                mullvad status &>/dev/null && return 0
            fi
            ;;
        nordvpn)
            if command -v nordvpn &>/dev/null; then
                nordvpn status &>/dev/null && return 0
            fi
            ;;
        protonvpn)
            if command -v protonvpn-cli &>/dev/null; then
                protonvpn-cli status &>/dev/null && return 0
            fi
            ;;
        *)
            vlog "No auth method for provider: ${provider_name}"
            ;;
    esac

    return 1
}

provider_list_servers() {
    local provider_name="${1}"
    local provider_config="${PROVIDERS_DIR}/${provider_name}/config.json"
    local servers_file="${PROVIDERS_DIR}/${provider_name}/servers.json"

    # Try plugin first
    if source_provider_plugin "${provider_name}"; then
        if declare -f "list_servers_${provider_name}" &>/dev/null; then
            "list_servers_${provider_name}"
            return $?
        fi
    fi

    # Fallback: read static servers.json
    if [[ -f "${servers_file}" ]]; then
        cat "${servers_file}"
        return 0
    fi

    # Fallback: read WG configs from provider dir
    local wg_dir="${PROVIDERS_DIR}/${provider_name}"
    if [[ -d "${wg_dir}" ]]; then
        local servers='[]'
        local i=0
        for conf in "${wg_dir}"/*.conf; do
            [[ -f "${conf}" ]] || continue
            local name
            name=$(basename "${conf}" .conf)
            local country=""
            country=$(echo "${name}" | grep -oEi '[a-z]{2}' | head -1 || true)
            servers=$(echo "${servers}" | jq --arg n "${name}" --arg c "${conf}" --arg cc "${country}" \
                '. + [{"name": $n, "conf": $c, "country": $cc, "type": "wireguard", "provider": "'"${provider_name}"'"}]')
            i=$((i+1))
        done
        if [[ ${i} -gt 0 ]]; then
            echo "${servers}"
            return 0
        fi
    fi

    echo '[]'
    return 0
}

build_server_pool() {
    log "Building unified server pool..."
    local pool='[]'
    local total=0

    # 1. Providers directory
    for provider_dir in "${PROVIDERS_DIR}"/*/; do
        [[ -d "${provider_dir}" ]] || continue
        local provider_name
        provider_name=$(basename "${provider_dir}")

        local p_servers
        p_servers=$(provider_list_servers "${provider_name}" 2>/dev/null || echo '[]')
        local p_count
        p_count=$(echo "${p_servers}" | jq length 2>/dev/null || echo 0)

        if [[ ${p_count} -gt 0 ]]; then
            pool=$(echo "${pool}" "${p_servers}" | jq -s '.[0] + .[1]')
            total=$((total + p_count))
            ok "Provider ${provider_name}: ${p_count} servers"
        fi
    done

    # 2. Direct servers from SERVERS_FILE
    if [[ -f "${SERVERS_FILE}" ]]; then
        local s_count
        s_count=$(jq length "${SERVERS_FILE}" 2>/dev/null || echo 0)
        if [[ ${s_count} -gt 0 ]]; then
            pool=$(echo "${pool}" "$(cat "${SERVERS_FILE}")" | jq -s '.[0] + .[1]')
            total=$((total + s_count))
            ok "Direct servers: ${s_count}"
        fi
    fi

    # 3. Oracle VMs
    if [[ -f "${ORACLE_VMS_FILE}" ]]; then
        local vm_count
        vm_count=$(jq length "${ORACLE_VMS_FILE}" 2>/dev/null || echo 0)
        if [[ ${vm_count} -gt 0 ]]; then
            pool=$(echo "${pool}" "$(cat "${ORACLE_VMS_FILE}")" | jq -s '.[0] + .[1]')
            total=$((total + vm_count))
            ok "Oracle VMs: ${vm_count}"
        fi
    fi

    echo "${pool}" > "${STATE_DIR}/server_pool.json"
    ok "Server pool built: ${total} total endpoints"
}

