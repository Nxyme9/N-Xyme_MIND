fix_opencode_config() {
    local cfg="${PROJECT_ROOT}/config/opencode.json"
    local omo="${PROJECT_ROOT}/config/oh-my-opencode.json"

    if [[ ! -f "${cfg}" ]]; then
        err "OpenCode config not found: ${cfg}"
        return 1
    fi

    log "Applying OpenCode config fixes..."

    # Create backups before modifying
    local backup_dir="${CONFIG_DIR}/backups/$(date +%Y%m%d_%H%M%S)"
    mkdir -p "${backup_dir}"
    cp "${cfg}" "${backup_dir}/opencode.json.bak" 2>/dev/null || true
    [[ -f "${omo}" ]] && cp "${omo}" "${backup_dir}/oh-my-opencode.json.bak" 2>/dev/null || true
    vlog "Config backups saved to ${backup_dir}"

    if ! command -v jq &>/dev/null; then
        err "jq required for config fixes"
        return 1
    fi

    # Fix 1: small_model (gpt-5-nano → minimax-m2.5-free)
    local current_small
    current_small=$(jq -r '.small_model // ""' "${cfg}")
    if [[ "${current_small}" == "gpt-5-nano" ]] || [[ "${current_small}" == "opencode/gpt-5-nano" ]]; then
        jq '.small_model = "opencode/minimax-m2.5-free"' "${cfg}" > "${cfg}.tmp" && mv "${cfg}.tmp" "${cfg}"
        ok "Fixed small_model: gpt-5-nano → opencode/minimax-m2.5-free"
    elif [[ -n "${current_small}" ]]; then
        ok "small_model: ${current_small}"
    fi

    # Fix 2: multimodal-looker model
    if [[ -f "${omo}" ]]; then
        local mm_model
        mm_model=$(jq -r '.agents["multimodal-looker"].model // ""' "${omo}" 2>/dev/null || echo "")
        if [[ "${mm_model}" != "opencode/mimo-v2-omni-free" ]]; then
            jq '.agents["multimodal-looker"].model = "opencode/mimo-v2-omni-free"' \
                "${omo}" > "${omo}.tmp" && mv "${omo}.tmp" "${omo}"
            ok "Fixed multimodal-looker model → opencode/mimo-v2-omni-free"
        else
            ok "multimodal-looker model already correct"
        fi

        # Fix 3: Disable compression hooks
        local disabled_hooks
        disabled_hooks=$(jq -r '.disabled_hooks // [] | .[]' "${omo}" 2>/dev/null || echo "")
        if ! echo "${disabled_hooks}" | grep -q "context-window-monitor"; then
            jq '.disabled_hooks = ((.disabled_hooks // []) + ["context-window-monitor", "preemptive-compaction"]) | .disabled_hooks |= unique' \
                "${omo}" > "${omo}.tmp" && mv "${omo}.tmp" "${omo}"
            ok "Disabled compression hooks"
        else
            ok "Compression hooks already disabled"
        fi

        # Fix 4: Ensure all agents have fallback_models
        local agents_needing_fallback
        agents_needing_fallback=$(jq -r '
            .agents | to_entries[] | select(.value.fallback_models == null) | .key
        ' "${omo}" 2>/dev/null || echo "")

        if [[ -n "${agents_needing_fallback}" ]]; then
            local tmp_omo="${omo}.tmp"
            cp "${omo}" "${tmp_omo}"
            while IFS= read -r agent; do
                [[ -z "${agent}" ]] && continue
                jq --arg a "${agent}" \
                    '.agents[$a].fallback_models = ["opencode/minimax-m2.5-free", "opencode/kimi-k2.5-free"]' \
                    "${tmp_omo}" > "${tmp_omo}.swap" && mv "${tmp_omo}.swap" "${tmp_omo}"
                ok "Added fallback_models to agent: ${agent}"
            done <<< "${agents_needing_fallback}"
            mv "${tmp_omo}" "${omo}"
        else
            ok "All agents have fallback_models"
        fi
    fi

    # Fix 5: Ensure enabled_providers includes all available providers
    jq '.enabled_providers = ["opencode", "openrouter", "groq", "cerebras", "deepseek", "ollama"] | .enabled_providers |= unique' \
        "${cfg}" > "${cfg}.tmp" && mv "${cfg}.tmp" "${cfg}"
    ok "enabled_providers updated"

    # Validate JSON
    if jq empty "${cfg}" 2>/dev/null; then
        ok "opencode.json is valid JSON"
    else
        err "opencode.json is INVALID — restoring backup"
        cp "${backup_dir}/opencode.json.bak" "${cfg}"
    fi
    if [[ -f "${omo}" ]] && jq empty "${omo}" 2>/dev/null; then
        ok "oh-my-opencode.json is valid JSON"
    elif [[ -f "${omo}" ]]; then
        err "oh-my-opencode.json is INVALID — restoring backup"
        cp "${backup_dir}/oh-my-opencode.json.bak" "${omo}"
    fi

    log "Config fixes complete. Relaunch OpenCode to apply."
}

