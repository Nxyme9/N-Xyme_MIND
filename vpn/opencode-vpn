                python3)
                    echo -e "    ${BOLD}Python 3.10+:${NC} apt install python3  # or brew install python3" ;;
                curl)
                    echo -e "    ${BOLD}curl:${NC} apt install curl  # or brew install curl" ;;
                jq)
                    echo -e "    ${BOLD}jq:${NC} apt install jq  # or brew install jq" ;;
                ssh)
                    echo -e "    ${BOLD}ssh:${NC} apt install openssh-client" ;;
                wg)
                    echo -e "    ${BOLD}wireguard-tools:${NC} apt install wireguard-tools  # or brew install wireguard-tools" ;;
            esac
        done
        echo ""
        die "Install missing deps and re-run."
    fi

