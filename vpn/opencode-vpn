#!/usr/bin/env bash
# ════════════════════════════════════════════════════════════════════════════════
# opencode-vpn — VPN rotation + rate-limit shield for OpenCode
#
# Features:
#   - WireProxy SOCKS5 per VPN server (multi-IP rotation)
#   - Python HTTP CONNECT rotator with 429 auto-switch
#   - Predictive switching (token-bucket per IP, switch at 80% quota)
#   - Provider fallback chain (OpenRouter -> Groq -> Cerebras -> DeepSeek -> Ollama)
#   - Health checking on startup + periodic
#   - Fastest-server selection (ping-sort)
#   - Quota dashboard (ANSI terminal)
#   - Guardrails (max-retry, exponential backoff, kill-switch, no IP leak)
#   - Oracle Cloud VM integration (SSH SOCKS5 proxies)
#   - OpenCode config auto-fix on first run
#   - VPN provider plugin system (mullvad, nordvpn, protonvpn, surfshark, wireguard, oracle)
#   - Credential management (keyring + file, never plaintext passwords)
#
# Usage:
#   bin/opencode-vpn                  # interactive setup + start
#   bin/opencode-vpn --start          # start with existing config
#   bin/opencode-vpn --stop           # stop all proxies
#   bin/opencode-vpn --status         # show status
#   bin/opencode-vpn --dashboard      # show quota dashboard only
#   bin/opencode-vpn --fix-config     # fix OpenCode config only
#   bin/opencode-vpn --add-vm         # add Oracle Cloud VM
#   bin/opencode-vpn --health         # one-shot health check
#   bin/opencode-vpn --countries XX   # filter by country code
#   bin/opencode-vpn --count N        # number of VPN endpoints
# ════════════════════════════════════════════════════════════════════════════════
set -euo pipefail

# ── Constants & Config ─────────────────────────────────────────────────────────
VERSION="0.1.0"
SCRIPT_NAME="opencode-vpn"
CONFIG_DIR="${HOME}/.config/opencode-vpn"
STATE_DIR="${CONFIG_DIR}/state"
WIREPROXY_CONF_DIR="${CONFIG_DIR}/wireproxy"
PROVIDERS_DIR="${CONFIG_DIR}/providers"
SERVERS_FILE="${STATE_DIR}/servers.json"
ORACLE_VMS_FILE="${STATE_DIR}/oracle-vms.json"
PID_FILE="${STATE_DIR}/pids"
LOG_FILE="${CONFIG_DIR}/vpn.log"
ROTATOR_PORT=18080
SOCKS_BASE_PORT=11080
HEALTH_INTERVAL=300
MAX_RETRIES=5
IS_LIVE_USB=false
NM_AVAILABLE=true
WG_MODULE=true
PROTONVPN_TIER="unknown"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ── Logging & Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
VERBOSE=0

log()  { echo -e "${CYAN}[$(date +%H:%M:%S)]${NC} $*" | tee -a "${LOG_FILE}" 2>/dev/null || echo -e "${CYAN}[$(date +%H:%M:%S)]${NC} $*"; }
ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }
die()  { err "$*"; exit 1; }
vlog() { [[ "${VERBOSE}" -eq 1 ]] && log "[VERBOSE] $*" || true; }

# ── Ensure directories ────────────────────────────────────────────────────────
mkdir -p "${CONFIG_DIR}" "${STATE_DIR}" "${WIREPROXY_CONF_DIR}" "${PROVIDERS_DIR}"
touch "${LOG_FILE}"

# ════════════════════════════════════════════════════════════════════════════════
# SECTION 1: DEPENDENCY CHECK + AUTO-INSTALL
# ════════════════════════════════════════════════════════════════════════════════

check_environment() {
    log "Checking environment..."

    # Detect live USB vs installed system
    if mount | grep -q "/run/media/" || [[ -d /run/live/ ]] || grep -q "live" /proc/cmdline 2>/dev/null; then
        warn "Running from LIVE USB — VPN may not work (limited NetworkManager, no persistence)"
        IS_LIVE_USB=true
    else
        IS_LIVE_USB=false
    fi

    # Check NetworkManager
    if systemctl is-active NetworkManager &>/dev/null; then
        vlog "NetworkManager: active"
        NM_AVAILABLE=true
    else
        warn "NetworkManager not running — protonvpn CLI may fail"
        NM_AVAILABLE=false
    fi

    # Check WireGuard kernel module
    if lsmod | grep -q wireguard || modprobe wireguard 2>/dev/null; then
        vlog "WireGuard kernel module: loaded"
        WG_MODULE=true
    else
        warn "WireGuard kernel module not available — wireproxy may fail"
        WG_MODULE=false
    fi

    # Check ProtonVPN GUI conflict (CLI and GUI can't run simultaneously)
    if pgrep -f "protonvpn-app\|proton-vpn-qt-app" &>/dev/null; then
        warn "ProtonVPN GUI detected — killing it (CLI and GUI can't run simultaneously)"
        pkill -f "protonvpn-app\|proton-vpn-qt-app" 2>/dev/null || true
        sleep 2
    fi

    # Check ProtonVPN daemon conflict
    if pgrep -f "proton.vpn.daemon" &>/dev/null; then
        vlog "ProtonVPN daemon running — may need to stop for CLI"
    fi

    # Check ProtonVPN state
    if command -v protonvpn &>/dev/null; then
        local pv_status
        pv_status=$(protonvpn status 2>/dev/null || echo "unknown")
        if echo "$pv_status" | grep -qi "connected"; then
            warn "ProtonVPN already connected — disconnecting first"
            protonvpn disconnect 2>/dev/null || true
            sleep 2
        fi
        # Clean up stale kill-switch if protonvpn failed before
        if nmcli connection show --active 2>/dev/null | grep -qi "kill"; then
            warn "Stale kill-switch detected — cleaning up"
            nmcli connection delete $(nmcli -t -f NAME connection show --active | grep -i kill) 2>/dev/null || true
        fi

        # Detect ProtonVPN tier (free vs Plus)
        detect_protonvpn_tier
    fi

    # Check disk space for logs/cache
    local avail_mb
    avail_mb=$(df -m "$CONFIG_DIR" 2>/dev/null | tail -1 | awk '{print $4}')
    if [[ -n "$avail_mb" ]] && [[ "$avail_mb" -lt 100 ]]; then
        warn "Low disk space (${avail_mb}MB) — may cause issues"
    fi

    ok "Environment check complete"
}

detect_protonvpn_tier() {
    # Try to determine if user has Free or Plus tier
    # Free tier: can't select countries, limited servers
    # Plus tier: full country selection, all features

    # Method 1: Try country selection (fails on free)
    local test_result
    test_result=$(protonvpn connect --country US 2>&1 | head -1)
    if echo "$test_result" | grep -qi "free plan\|not available\|upgrade"; then
        PROTONVPN_TIER="free"
        log "ProtonVPN tier: FREE (country selection limited)"
    else
        # Disconnect the test connection
        protonvpn disconnect 2>/dev/null || true
        sleep 1
        PROTONVPN_TIER="plus"
        log "ProtonVPN tier: PLUS (full country selection)"
    fi

    # Method 2: Check account info
    local info
    info=$(protonvpn info 2>/dev/null)
    if echo "$info" | grep -qi "plus\|vision\|unlimited"; then
        PROTONVPN_TIER="plus"
    elif echo "$info" | grep -qi "free"; then
        PROTONVPN_TIER="free"
    fi

    vlog "ProtonVPN tier detected: $PROTONVPN_TIER"
}

check_deps() {
