install_wireproxy() {
    log "Installing wireproxy..."
    local arch
    arch=$(uname -m)
    case "${arch}" in
        x86_64)  arch="amd64" ;;
        aarch64) arch="arm64" ;;
        armv7l)  arch="armv7" ;;
        *)       die "Unsupported architecture: ${arch}" ;;
    esac
    local url="https://github.com/pufferffish/wireproxy/releases/latest/download/wireproxy_linux_${arch}.tar.gz"
    local tmp_tar
    tmp_tar=$(mktemp /tmp/wireproxy-XXXXXX.tar.gz)
    if curl -sL "${url}" -o "${tmp_tar}" && tar xzf "${tmp_tar}" -C /tmp/ 2>/dev/null; then
        if sudo mv /tmp/wireproxy /usr/local/bin/ 2>/dev/null; then
            ok "wireproxy installed to /usr/local/bin/"
        else
            mv /tmp/wireproxy "${CONFIG_DIR}/"
            chmod +x "${CONFIG_DIR}/wireproxy"
            ok "wireproxy installed to ${CONFIG_DIR}/"
        fi
    else
        warn "Could not auto-install wireproxy. Install manually:"
        echo "  https://github.com/pufferffish/wireproxy/releases"
    fi
    rm -f "${tmp_tar}"
}

