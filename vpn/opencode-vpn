# ── MAIN ───────────────────────────────────────────────────────────────────

async def main():
    if "--dashboard" in sys.argv:
        if DASHBOARD_FILE.exists():
            with open(DASHBOARD_FILE) as f:
                data = json.load(f)
            print_dashboard_from_data(data)
        else:
            print("No dashboard data yet — rotator not running?")
        return

    state.load_backends()
    state.provider_available = get_provider_status()

    log.info(f"{C_BOLD}opencode-vpn rotator starting{C_NC}")
    log.info(f"  Listen: {LISTEN_HOST}:{LISTEN_PORT}")
    log.info(f"  Backends: {len(state.backends)}")
    log.info(f"  Max retries: {MAX_RETRIES}")
    log.info(f"  Kill switch: {'ON' if KILL_SWITCH else 'OFF'}")
    log.info(f"  Providers: {[p for p, a in state.provider_available.items() if a]}")

    server = await asyncio.start_server(handle_connect, LISTEN_HOST, LISTEN_PORT)

    asyncio.create_task(health_check_loop())
    asyncio.create_task(dashboard_loop())

    loop = asyncio.get_event_loop()
    for sig in (signal.SIGINT, signal.SIGTERM):
        loop.add_signal_handler(sig, lambda: asyncio.create_task(shutdown(server)))

    async with server:
        await server.serve_forever()


async def shutdown(server):
    log.info("Shutting down rotator...")
    server.close()
    await server.wait_closed()
    pid_file = CONFIG_DIR / "rotator.pid"
    if pid_file.exists():
        pid_file.unlink()
    sys.exit(0)


