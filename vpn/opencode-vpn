# ════════════════════════════════════════════════════════════════════════════════
# SECTION 10: PYTHON ROTATOR (EMBEDDED)
# ════════════════════════════════════════════════════════════════════════════════

write_rotator_script() {
    cat > "${CONFIG_DIR}/rotator.py" << 'PYTHON_EOF'
#!/usr/bin/env python3
"""
opencode-vpn rotator: HTTP CONNECT proxy with intelligent rotation.

Features:
  - Round-robin across SOCKS5 backends (WireProxy + SSH)
  - 429 detection + immediate auto-switch
  - Token-bucket per IP (predictive switching at 80% quota)
  - Provider fallback chain when all IPs exhausted
  - Health checking (periodic)
  - Quota dashboard (ANSI terminal output)
  - Guardrails (max-retry, exponential backoff, kill-switch)
"""

import asyncio
import json
import os
import sys
import time
import socket
import struct
import logging
import signal
from dataclasses import dataclass, field
from pathlib import Path
from typing import Optional

# ── Config ─────────────────────────────────────────────────────────────────

CONFIG_DIR = Path(os.environ.get("VPN_CONFIG_DIR", str(Path.home() / ".config/opencode-vpn")))
STATE_DIR = CONFIG_DIR / "state"
DASHBOARD_FILE = STATE_DIR / "dashboard.json"
LISTEN_HOST = "127.0.0.1"
LISTEN_PORT = int(os.environ.get("ROTATOR_PORT", "18080"))
MAX_RETRIES = int(os.environ.get("VPN_MAX_RETRIES", "5"))
BACKOFF_BASE = float(os.environ.get("VPN_BACKOFF_BASE", "1.0"))
BACKOFF_MAX = float(os.environ.get("VPN_BACKOFF_MAX", "30.0"))
PREDICTIVE_THRESHOLD = float(os.environ.get("VPN_PREDICTIVE_THRESHOLD", "0.8"))
TOKEN_BUCKET_CAPACITY = int(os.environ.get("VPN_BUCKET_CAPACITY", "60"))
TOKEN_BUCKET_REFILL = float(os.environ.get("VPN_BUCKET_REFILL", "60.0"))
HEALTH_CHECK_INTERVAL = int(os.environ.get("VPN_HEALTH_INTERVAL", "300"))
KILL_SWITCH = os.environ.get("VPN_KILL_SWITCH", "1") == "1"

PROVIDER_FALLBACK_CHAIN = [
    "openrouter", "groq", "cerebras", "deepseek", "ollama",
]

C_RED = "\033[0;31m"
C_GREEN = "\033[0;32m"
C_YELLOW = "\033[1;33m"
C_CYAN = "\033[0;36m"
C_BOLD = "\033[1m"
C_DIM = "\033[2m"
C_NC = "\033[0m"

logging.basicConfig(
    level=logging.INFO,
    format=f"{C_DIM}%(asctime)s{C_NC} %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger("rotator")


# ── Token Bucket ───────────────────────────────────────────────────────────

@dataclass
class TokenBucket:
    """Token bucket for rate-limit prediction per IP."""
    capacity: int = TOKEN_BUCKET_CAPACITY
    tokens: float = TOKEN_BUCKET_CAPACITY
    last_refill: float = field(default_factory=time.monotonic)
    request_count: int = 0
    rate_limited_count: int = 0
    last_429_time: float = 0.0
    observed_quota: Optional[int] = None

    def consume(self) -> bool:
        self._refill()
        if self.tokens >= 1:
            self.tokens -= 1
            self.request_count += 1
            return True
        return False

    def _refill(self):
        now = time.monotonic()
        elapsed = now - self.last_refill
        refill_rate = self.capacity / TOKEN_BUCKET_REFILL
        self.tokens = min(self.capacity, self.tokens + elapsed * refill_rate)
        self.last_refill = now

    @property
    def usage_fraction(self) -> float:
        self._refill()
        return 1.0 - (self.tokens / self.capacity)

    @property
    def should_predictive_switch(self) -> bool:
        if self.observed_quota and self.request_count >= self.observed_quota * PREDICTIVE_THRESHOLD:
            return True
        return self.usage_fraction >= PREDICTIVE_THRESHOLD

    def record_429(self):
        self.rate_limited_count += 1
        self.last_429_time = time.monotonic()
        self.observed_quota = self.request_count


# ── Backend ────────────────────────────────────────────────────────────────

@dataclass
class Backend:
    name: str
    host: str
    port: int
    bucket: TokenBucket = field(default_factory=TokenBucket)
    healthy: bool = True
    current_ip: Optional[str] = None
    last_health_check: float = 0.0
    total_requests: int = 0
    total_429s: int = 0
    total_successes: int = 0

    @property
    def socks_addr(self) -> tuple:
        return (self.host, self.port)

    @property
    def success_rate(self) -> float:
        if self.total_requests == 0:
            return 1.0
        return self.total_successes / self.total_requests


# ── Rotator State ──────────────────────────────────────────────────────────

class RotatorState:
    def __init__(self):
        self.backends: list[Backend] = []
        self.current_index: int = 0
        self.provider_available: dict[str, bool] = {
            p: bool(os.environ.get(f"{p.upper()}_API_KEY"))
            for p in PROVIDER_FALLBACK_CHAIN
        }
        self.provider_available["ollama"] = True
        self.exhausted_ips: set[str] = set()
        self.start_time: float = time.monotonic()
        self.total_rotations: int = 0
        self.total_fallbacks: int = 0
        self._lock = asyncio.Lock()

    def load_backends(self):
        sorted_file = STATE_DIR / "sorted_servers.json"
        if sorted_file.exists():
            with open(sorted_file) as f:
                servers = json.load(f)
            for srv in servers:
                self.backends.append(Backend(
                    name=f"port-{srv['port']}",
                    host="127.0.0.1",
                    port=srv["port"],
                ))
        else:
            base = int(os.environ.get("SOCKS_BASE_PORT", "11080"))
            for port in range(base, base + 50):
                try:
                    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                    s.settimeout(0.5)
                    s.connect(("127.0.0.1", port))
                    s.close()
                    self.backends.append(Backend(
                        name=f"port-{port}",
                        host="127.0.0.1",
                        port=port,
                    ))
                except (ConnectionRefusedError, socket.timeout, OSError):
                    pass

        if not self.backends:
            log.warning("No SOCKS5 backends found — will use direct + provider fallback")
        else:
            log.info(f"Loaded {len(self.backends)} SOCKS5 backends")

    async def get_next_backend(self) -> Optional[Backend]:
        async with self._lock:
            if not self.backends:
                return None

            attempts = 0
            while attempts < len(self.backends):
                idx = (self.current_index + attempts) % len(self.backends)
                backend = self.backends[idx]

                if backend.healthy and not backend.bucket.should_predictive_switch:
                    self.current_index = (idx + 1) % len(self.backends)
                    return backend

                attempts += 1

            log.warning(f"{C_YELLOW}All VPN IPs at quota — selecting least-used{C_NC}")
            least_used = min(self.backends, key=lambda b: b.bucket.request_count)
            self.total_rotations += 1
            return least_used

    def mark_rate_limited(self, backend: Backend):
        backend.bucket.record_429()
        backend.total_429s += 1
        log.warning(f"{C_RED}429 on {backend.name} (total: {backend.total_429s}){C_NC}")

    def get_dashboard_data(self) -> dict:
        uptime = time.monotonic() - self.start_time
        backends_data = []
        for b in self.backends:
            if b.bucket.observed_quota:
                remaining = max(0, b.bucket.observed_quota - b.bucket.request_count)
                reset_estimate = 60 - (time.monotonic() % 60)
            else:
                remaining = int(b.bucket.tokens)
                reset_estimate = TOKEN_BUCKET_REFILL * (1 - b.bucket.tokens / b.bucket.capacity)

            backends_data.append({
                "name": b.name,
                "port": b.port,
                "healthy": b.healthy,
                "ip": b.current_ip,
                "requests": b.bucket.request_count,
                "429s": b.bucket.rate_limited_count,
                "quota_remaining": remaining,
                "quota_observed": b.bucket.observed_quota,
                "reset_in_seconds": round(reset_estimate),
                "usage_pct": round(b.bucket.usage_fraction * 100),
                "success_rate": round(b.success_rate * 100, 1),
                "predictive_switch": b.bucket.should_predictive_switch,
            })

        return {
            "uptime_seconds": round(uptime),
            "total_backends": len(self.backends),
            "healthy_backends": sum(1 for b in self.backends if b.healthy),
            "total_rotations": self.total_rotations,
            "total_fallbacks": self.total_fallbacks,
            "providers": self.provider_available,
            "backends": backends_data,
        }


state = RotatorState()


# ── SOCKS5 CONNECT ─────────────────────────────────────────────────────────

async def socks5_connect(backend: Backend, dest_host: str, dest_port: int):
    try:
        reader, writer = await asyncio.wait_for(
            asyncio.open_connection(backend.host, backend.port),
            timeout=10.0,
        )

        writer.write(b"\x05\x01\x00")
        await writer.drain()

        resp = await asyncio.wait_for(reader.read(2), timeout=5.0)
        if len(resp) < 2 or resp[1] != 0x00:
            writer.close()
            return None

        dest_bytes = dest_host.encode("utf-8")
        req = struct.pack("!BBBB", 5, 1, 0, 3) + struct.pack("!B", len(dest_bytes)) + dest_bytes + struct.pack("!H", dest_port)
        writer.write(req)
        await writer.drain()

        resp = await asyncio.wait_for(reader.read(10), timeout=5.0)
        if len(resp) < 2 or resp[1] != 0x00:
            writer.close()
            return None

        return reader, writer

    except (asyncio.TimeoutError, ConnectionRefusedError, OSError) as e:
        backend.healthy = False
        log.warning(f"SOCKS5 failed for {backend.name}: {e}")
        return None


# ── HTTP CONNECT HANDLER ───────────────────────────────────────────────────

async def handle_connect(client_reader: asyncio.StreamReader, client_writer: asyncio.StreamWriter):
    try:
        request_line = await asyncio.wait_for(client_reader.readline(), timeout=30.0)
        if not request_line:
            return

        headers = {}
        while True:
            line = await asyncio.wait_for(client_reader.readline(), timeout=10.0)
            if line in (b"\r\n", b"\n", b""):
                break
            if b":" in line:
                key, val = line.split(b":", 1)
                headers[key.strip().lower()] = val.strip()

        parts = request_line.decode("utf-8", errors="replace").strip().split()
        if len(parts) < 2 or parts[0].upper() != "CONNECT":
            client_writer.write(b"HTTP/1.1 400 Bad Request\r\n\r\n")
            await client_writer.drain()
            return

        target = parts[1]
        if ":" in target:
            dest_host, dest_port = target.rsplit(":", 1)
            dest_port = int(dest_port)
        else:
            dest_host = target
            dest_port = 443

        # ── Kill switch ──
        if KILL_SWITCH and not state.backends:
            allowed_hosts = [
                "api.openrouter.ai", "api.groq.com", "api.cerebras.ai",
                "api.deepseek.com", "localhost", "127.0.0.1",
            ]
            if not any(dest_host.endswith(h) for h in allowed_hosts):
                log.warning(f"{C_RED}Kill switch: blocked {dest_host} (no VPN){C_NC}")
                client_writer.write(b"HTTP/1.1 503 Service Unavailable\r\n\r\n")
                await client_writer.drain()
                return

        # ── Retry loop with 429 detection ──
        retry_count = 0
        backoff = BACKOFF_BASE
        tried_backends: set[int] = set()

        while retry_count < MAX_RETRIES:
            backend = await state.get_next_backend()

            if backend is None:
                log.info(f"Direct connect to {dest_host}:{dest_port} (no VPN)")
                break

            if id(backend) in tried_backends and retry_count > 0:
                log.warning(f"{C_YELLOW}All VPN backends tried — using direct{C_NC}")
                state.total_fallbacks += 1
                break

            tried_backends.add(id(backend))
            backend.total_requests += 1

            result = await socks5_connect(backend, dest_host, dest_port)
            if result is None:
                retry_count += 1
                log.warning(f"Retry {retry_count}/{MAX_RETRIES} — {backend.name} failed, switching...")
                await asyncio.sleep(min(backoff, BACKOFF_MAX))
                backoff *= 2
                continue

            server_reader, server_writer = result

            client_writer.write(b"HTTP/1.1 200 Connection Established\r\n\r\n")
            await client_writer.drain()

            try:
                await tunnel_with_429_detection(
                    client_reader, client_writer,
                    server_reader, server_writer,
                    backend, dest_host,
                )
                backend.total_successes += 1
            except Exception as e:
                log.warning(f"Tunnel error via {backend.name}: {e}")
            finally:
                server_writer.close()
                try:
                    await server_writer.wait_closed()
                except Exception:
                    pass
            return

        # ── Fallback: direct connect ──
        try:
            server_reader, server_writer = await asyncio.wait_for(
                asyncio.open_connection(dest_host, dest_port),
                timeout=15.0,
            )
            client_writer.write(b"HTTP/1.1 200 Connection Established\r\n\r\n")
            await client_writer.drain()
            await tunnel_bidirectional(client_reader, client_writer, server_reader, server_writer)
            server_writer.close()
            try:
                await server_writer.wait_closed()
            except Exception:
                pass
        except Exception as e:
            log.error(f"Direct connect failed to {dest_host}:{dest_port}: {e}")
            client_writer.write(b"HTTP/1.1 502 Bad Gateway\r\n\r\n")
            await client_writer.drain()

    except Exception as e:
        log.error(f"Handler error: {e}")
    finally:
        client_writer.close()
        try:
            await client_writer.wait_closed()
        except Exception:
            pass


# ── TUNNEL WITH 429 DETECTION ──────────────────────────────────────────────

async def tunnel_with_429_detection(
    client_r, client_w, server_r, server_w, backend, dest_host,
):
    client_to_server = asyncio.create_task(relay(client_r, server_w))
    server_to_client = asyncio.create_task(relay_with_429_watch(server_r, client_w, backend, dest_host))

    done, pending = await asyncio.wait(
        [client_to_server, server_to_client],
        return_when=asyncio.FIRST_COMPLETED,
    )
    for task in pending:
        task.cancel()
        try:
            await task
        except Exception:
            pass
    for task in done:
        if task.exception():
            raise task.exception()


async def relay_with_429_watch(reader, writer, backend, dest_host):
    try:
        while True:
            data = await reader.read(65536)
            if not data:
                break

            text = data[:512].decode("utf-8", errors="ignore")
            if "HTTP/" in text and " 429 " in text:
                state.mark_rate_limited(backend)

            writer.write(data)
            await writer.drain()
    except (asyncio.CancelledError, ConnectionResetError, BrokenPipeError):
        pass


async def relay(reader, writer):
    try:
        while True:
            data = await reader.read(65536)
            if not data:
                break
            writer.write(data)
            await writer.drain()
    except (asyncio.CancelledError, ConnectionResetError, BrokenPipeError):
        pass


async def tunnel_bidirectional(client_r, client_w, server_r, server_w):
    await asyncio.gather(
        relay(client_r, server_w),
        relay(server_r, client_w),
        return_exceptions=True,
    )


