        # Rotator not running — show static status
        warn "Rotator is not running — showing static status"
        status_vpn
    fi
}

# ════════════════════════════════════════════════════════════════════════════════
# SECTION 13: COMMANDS & MAIN ENTRYPOINT
# ════════════════════════════════════════════════════════════════════════════════

usage() {
    echo ""
    echo -e "${BOLD}opencode-vpn v${VERSION}${NC} — VPN rotation + rate-limit shield for OpenCode"
    echo ""
    echo "Usage: ${SCRIPT_NAME} [COMMAND] [OPTIONS]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo "  --start            Start VPN rotation shield (default)"
    echo "  --stop             Stop all proxies and rotator"
    echo "  --status           Show running instances, quota, health"
    echo "  --dashboard        Live quota dashboard"
    echo "  --fix-config       Apply OpenCode config fixes only"
    echo "  --add-vm           Add Oracle Cloud VM as SOCKS5 proxy"
    echo "  --health           One-shot health check on all proxies"
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo "  --countries CODE   Filter by country code (e.g., --countries us,de)"
    echo "  --count N          Number of VPN endpoints to use"
    echo "  -v, --verbose      Enable verbose logging"
    echo "  --version          Show version"
    echo "  --help             Show this help"
    echo ""
    echo -e "${BOLD}Config directory:${NC} ${CONFIG_DIR}/"
    echo -e "${BOLD}Log file:${NC}         ${LOG_FILE}"
    echo ""
}

cleanup() {
    local exit_code=$?
    vlog "Cleanup triggered (exit code: ${exit_code})"
    # Only stop proxies on unexpected exit, not on intentional stop
    if [[ ${exit_code} -ne 0 ]] && [[ -f "${CONFIG_DIR}/rotator.pid" ]]; then
        warn "Unexpected exit — stopping proxies..."
        stop_all_proxies 2>/dev/null || true
    fi
    exit "${exit_code}"
}

main() {
    local cmd="start"
    local filter_countries=""
    local endpoint_count=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --start|start)
                cmd="start"; shift ;;
            --stop|stop)
                cmd="stop"; shift ;;
            --status|status)
                cmd="status"; shift ;;
            --dashboard|dashboard)
                cmd="dashboard"; shift ;;
            --fix-config|fix-config)
                cmd="fix-config"; shift ;;
            --add-vm|add-vm)
                cmd="add-vm"; shift ;;
            --health|health)
                cmd="health"; shift ;;
            --countries)
                filter_countries="${2:-}"; shift 2 ;;
            --count)
                endpoint_count="${2:-}"; shift 2 ;;
            -v|--verbose)
                VERBOSE=1; shift ;;
            --version)
                echo "${SCRIPT_NAME} v${VERSION}"; exit 0 ;;
            --help|-h)
                usage; exit 0 ;;
            *)
                die "Unknown option: ${1} (try --help)" ;;
        esac
    done

    # Apply filters to environment
    [[ -n "${filter_countries}" ]] && export VPN_COUNTRIES="${filter_countries}"
    [[ -n "${endpoint_count}" ]] && export VPN_ENDPOINT_COUNT="${endpoint_count}"

    # Route to command
    case "${cmd}" in
        start)
            start_vpn "$@"
            ;;
        stop)
            stop_vpn
            ;;
        status)
            status_vpn
            ;;
        dashboard)
            show_dashboard
            ;;
        fix-config)
            fix_opencode_config
            ;;
        add-vm)
            init_servers_file
            add_oracle_vm
            ;;
        health)
            health_check_all
            ;;
        *)
            die "Unknown command: ${cmd} (try --help)"
            ;;
    esac
}

# ── Signal Handling ─────────────────────────────────────────────────────────
trap cleanup EXIT
trap 'echo ""; log "Interrupted (SIGINT) — stopping all proxies..."; stop_all_proxies; exit 0' INT
trap 'echo ""; log "Terminated (SIGTERM) — stopping all proxies..."; stop_all_proxies; exit 0' TERM

main "$@"
