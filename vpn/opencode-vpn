add_oracle_vm() {
    echo ""
    echo -e "${BOLD}═══ Add Oracle Cloud VM ═══${NC}"
    echo "Enter SSH connection strings for your Oracle VMs."
    echo "Format: user@host (e.g., opc@123.45.67.89)"
    echo "Press ENTER on empty line to finish."
    echo ""

    local vms
    vms=$(cat "${ORACLE_VMS_FILE}" 2>/dev/null || echo '[]')
    local i=0
    while true; do
        read -rp "  SSH connection [$((i+1))] (empty to stop): " ssh_conn
        [[ -z "${ssh_conn}" ]] && break

        log "Testing SSH to ${ssh_conn}..."
        if ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no "${ssh_conn}" "echo ok" &>/dev/null; then
            ok "SSH to ${ssh_conn} works"
        else
            warn "Cannot reach ${ssh_conn} — adding anyway (may need key setup)"
        fi

        local name="oracle-${i}"
        read -rp "  Friendly name [${name}]: " custom_name
        [[ -n "${custom_name}" ]] && name="${custom_name}"

        vms=$(echo "${vms}" | jq --arg n "${name}" --arg s "${ssh_conn}" \
            '. + [{"name": $n, "ssh": $s, "type": "oracle"}]')
        i=$((i+1))
    done

    echo "${vms}" > "${ORACLE_VMS_FILE}"
    chmod 600 "${ORACLE_VMS_FILE}"
    ok "Saved ${i} Oracle VMs to ${ORACLE_VMS_FILE}"
}

start_oracle_socks() {
    local vms
    vms=$(jq -r '.[] | "\(.name)|\(.ssh)"' "${ORACLE_VMS_FILE}" 2>/dev/null || echo "")
    [[ -z "${vms}" ]] && { vlog "No Oracle VMs configured"; return 0; }

    # Calculate port offset: skip past WireProxy ports
    local port=$((SOCKS_BASE_PORT))
    local server_count
    server_count=$(jq length "${SERVERS_FILE}" 2>/dev/null || echo 0)
    port=$((SOCKS_BASE_PORT + server_count * 10))

    local started=0
    while IFS='|' read -r name ssh_conn; do
        [[ -z "${name}" ]] && continue
        port=$((port + 1))
        log "Starting SSH SOCKS5 proxy ${name} on :${port} → ${ssh_conn}"
        ssh -o StrictHostKeyChecking=no -o ServerAliveInterval=30 \
            -o ServerAliveCountMax=3 -N -D "127.0.0.1:${port}" "${ssh_conn}" &>> "${LOG_FILE}" &
        echo "$!" >> "${PID_FILE}"
        ok "SSH proxy ${name} ready on :${port}"
        started=$((started+1))
    done <<< "${vms}"

    log "Started ${started} Oracle SOCKS5 proxies"
}

stop_oracle_socks() {
    log "Stopping Oracle SSH tunnels..."
    pkill -f "ssh.*-N.*-D" 2>/dev/null || true
    ok "Oracle SOCKS proxies stopped"
}

