# SECTION 2: CREDENTIAL MANAGEMENT
# ════════════════════════════════════════════════════════════════════════════════

check_config_exists() {
    if [[ ! -d "${CONFIG_DIR}" ]]; then
        vlog "Config directory does not exist yet: ${CONFIG_DIR}"
        return 1
    fi
    if [[ ! -f "${CONFIG_DIR}/config.json" ]]; then
        vlog "config.json not found"
        return 1
    fi
    return 0
}

prompt_credentials() {
    echo ""
    echo -e "${BOLD}═══ VPN Credentials Setup ═══${NC}"
    echo ""
    echo "Supported providers: ProtonVPN, Mullvad, WireGuard (generic)"
    echo ""

    local provider=""
    echo "Select provider:"
    echo "  1) ProtonVPN (username/password/2FA)"
    echo "  2) Mullvad (account number)"
    echo "  3) Generic WireGuard (config files only)"
    echo ""
    read -rp "Choice [1-3]: " provider_choice

    case "${provider_choice}" in
        1) provider="protonvpn" ;;
        2) provider="mullvad" ;;
        3) provider="wireguard" ;;
        *) provider="wireguard" ; warn "Defaulting to wireguard" ;;
    esac

    local username="" password="" twofa="" account_num="" wg_dir=""

    case "${provider}" in
        protonvpn)
            echo ""
            read -rp "  ProtonVPN username: " username
            read -rsp "  ProtonVPN password: " password
            echo ""
            read -rp "  2FA code (leave empty if none): " twofa
            echo ""
            ;;
        mullvad)
            echo ""
            read -rp "  Mullvad account number: " account_num
            echo ""
            ;;
        wireguard)
            echo ""
            echo "  Enter path to directory containing WireGuard .conf files:"
            read -rp "  WG config directory: " wg_dir
            if [[ ! -d "${wg_dir}" ]]; then
                warn "Directory not found: ${wg_dir}"
            fi
            echo ""
            ;;
    esac

    save_credentials "${provider}" "${username}" "${password}" "${twofa}" "${account_num}" "${wg_dir}"
}

prompt_oracle_vms() {
    echo ""
    echo -e "${BOLD}═══ Oracle Cloud VM Setup ═══${NC}"
    echo "Enter SSH connection strings for your Oracle VMs."
    echo "Format: user@host (e.g., opc@123.45.67.89)"
    echo "Press ENTER on empty line to finish."
    echo ""

    local vms
    vms=$(cat "${ORACLE_VMS_FILE}" 2>/dev/null || echo '[]')
    local i=0
    while true; do
        read -rp "  SSH connection [$((i+1))] (empty to stop): " ssh_conn
        [[ -z "${ssh_conn}" ]] && break

        log "Testing SSH to ${ssh_conn}..."
        if ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no "${ssh_conn}" "echo ok" &>/dev/null; then
            ok "SSH to ${ssh_conn} works"
        else
            warn "Cannot reach ${ssh_conn} — adding anyway (may need key setup)"
        fi

        local name="oracle-${i}"
        read -rp "  Friendly name [${name}]: " custom_name
        [[ -n "${custom_name}" ]] && name="${custom_name}"

        vms=$(echo "${vms}" | jq --arg n "${name}" --arg s "${ssh_conn}" \
            '. + [{"name": $n, "ssh": $s, "type": "oracle"}]')
        i=$((i+1))
    done

    echo "${vms}" > "${ORACLE_VMS_FILE}"
    chmod 600 "${ORACLE_VMS_FILE}"
    ok "Saved ${i} Oracle VMs to ${ORACLE_VMS_FILE}"
}

save_credentials() {
    local provider="${1}" username="${2}" password="${3}" twofa="${4}" account_num="${5}" wg_dir="${6}"

    # Save config metadata (non-sensitive)
    cat > "${CONFIG_DIR}/config.json" <<EOF
{
    "version": "${VERSION}",
    "provider": "${provider}",
    "wg_dir": "${wg_dir}",
    "created": "$(date -Iseconds)",
    "rotator_port": ${ROTATOR_PORT},
    "socks_base_port": ${SOCKS_BASE_PORT},
    "health_interval": ${HEALTH_INTERVAL}
}
EOF
    chmod 600 "${CONFIG_DIR}/config.json"

    # Save password/key to keyring if available, otherwise to restricted file
    if [[ -n "${password}" ]]; then
        if command -v secret-tool &>/dev/null; then
            echo -n "${password}" | secret-tool store --label="opencode-vpn-${provider}" service opencode-vpn user "${username}" 2>/dev/null
            ok "Password stored in system keyring"
        elif command -v pass &>/dev/null; then
            echo -n "${password}" | pass insert -m "opencode-vpn/${provider}/${username}" 2>/dev/null
            ok "Password stored in pass"
        else
            # Fallback: restricted file (chmod 600)
            cat > "${CONFIG_DIR}/.credentials" <<EOF
PROVIDER=${provider}
USERNAME=${username}
PASSWORD=${password}
TWOFA=${twofa}
ACCOUNT_NUM=${account_num}
EOF
            chmod 600 "${CONFIG_DIR}/.credentials"
            warn "Password saved to ${CONFIG_DIR}/.credentials (chmod 600)"
            warn "Consider installing 'pass' or 'secret-tool' for keyring storage"
        fi
    fi

    # Save Mullvad account number separately (not sensitive enough for keyring)
    if [[ -n "${account_num}" ]]; then
        echo "${account_num}" > "${CONFIG_DIR}/.mullvad_account"
        chmod 600 "${CONFIG_DIR}/.mullvad_account"
        ok "Mullvad account saved"
    fi

    ok "Credentials saved for provider: ${provider}"
}

load_credentials() {
    if [[ ! -f "${CONFIG_DIR}/config.json" ]]; then
        vlog "No config.json found"
        return 1
    fi

    local provider
    provider=$(jq -r '.provider // ""' "${CONFIG_DIR}/config.json" 2>/dev/null)
    vlog "Loading credentials for provider: ${provider}"

    # Try keyring first, then file fallback
    if [[ -f "${CONFIG_DIR}/.credentials" ]]; then
        # shellcheck source=/dev/null
        source "${CONFIG_DIR}/.credentials"
        vlog "Credentials loaded from file"
    fi

    # Load Mullvad account
    if [[ -f "${CONFIG_DIR}/.mullvad_account" ]]; then
        ACCOUNT_NUM=$(cat "${CONFIG_DIR}/.mullvad_account")
        vlog "Mullvad account loaded"
    fi

    return 0
}

# ════════════════════════════════════════════════════════════════════════════════
# SECTION 3: VPN SERVER CONFIG
# ════════════════════════════════════════════════════════════════════════════════

init_servers_file() {
    [[ -f "${SERVERS_FILE}" ]] || echo '[]' > "${SERVERS_FILE}"
    [[ -f "${ORACLE_VMS_FILE}" ]] || echo '[]' > "${ORACLE_VMS_FILE}"
}

prompt_vpn_servers() {
    if [[ -f "${SERVERS_FILE}" ]] && [[ $(jq length "${SERVERS_FILE}" 2>/dev/null) -gt 0 ]]; then
        local count
        count=$(jq length "${SERVERS_FILE}")
        log "Found ${count} VPN servers in config"
        return 0
    fi

    echo ""
    echo -e "${BOLD}═══ VPN Server Setup ═══${NC}"
    echo "Enter WireGuard config paths (one per line)."
    echo "Press ENTER on empty line to finish."
    echo ""

    local servers='[]'
    local i=0
    while true; do
        read -rp "  WG config path [$((i+1))] (empty to stop): " conf_path
        [[ -z "${conf_path}" ]] && break
        # Expand tilde
        conf_path="${conf_path/#\~/${HOME}}"
        if [[ ! -f "${conf_path}" ]]; then
            warn "File not found: ${conf_path} — skipping"
            continue
        fi
        local name="vpn-${i}"
        read -rp "  Friendly name [${name}]: " custom_name
        [[ -n "${custom_name}" ]] && name="${custom_name}"

        # Extract country from filename if present
        local country=""
        country=$(basename "${conf_path}" | grep -oEi '[a-z]{2}-[a-z]+' | head -1 | cut -d- -f1 || true)

        servers=$(echo "${servers}" | jq --arg n "${name}" --arg c "${conf_path}" --arg cc "${country}" \
            '. + [{"name": $n, "conf": $c, "country": $cc, "type": "wireguard"}]')
        i=$((i+1))
    done

    echo "${servers}" > "${SERVERS_FILE}"
    chmod 600 "${SERVERS_FILE}"
    ok "Saved ${i} servers to ${SERVERS_FILE}"
}

# ════════════════════════════════════════════════════════════════════════════════
# SECTION 4: WIREPROXY CONFIG MANAGEMENT
# ════════════════════════════════════════════════════════════════════════════════

generate_wireproxy_conf() {
    local wg_conf="${1}" socks_port="${2}" http_port="${3}" out_conf="${4}"

    # Read the original WireGuard config and append SOCKS5 + HTTP sections
    cat > "${out_conf}" <<EOF
# Auto-generated by opencode-vpn v${VERSION}
# Source: ${wg_conf}
# Generated: $(date -Iseconds)

EOF
    # Copy the WireGuard [Interface] and [Peer] sections
    cat "${wg_conf}" >> "${out_conf}"

    # Append WireProxy SOCKS5 and HTTP proxy sections
    cat >> "${out_conf}" <<EOF

[Socks5]
BindAddress = 127.0.0.1:${socks_port}

[http]
BindAddress = 127.0.0.1:${http_port}
EOF
    chmod 600 "${out_conf}"
    vlog "Generated WireProxy config: ${out_conf}"
}

start_wireproxy() {
    local name="${1}" wg_conf="${2}" socks_port="${3}"
    local http_port=$((socks_port + 1000))
    local wp_conf="${WIREPROXY_CONF_DIR}/${name}.conf"

    generate_wireproxy_conf "${wg_conf}" "${socks_port}" "${http_port}" "${wp_conf}"

    log "Starting wireproxy ${name} on :${socks_port} (SOCKS5) / :${http_port} (HTTP)"
    wireproxy -c "${wp_conf}" &>> "${LOG_FILE}" &
    local pid=$!
    echo "${pid}" >> "${PID_FILE}"

    # Wait for SOCKS5 to become ready (max 10 seconds)
    local retries=0
    while ! (echo > /dev/tcp/127.0.0.1/${socks_port}) 2>/dev/null; do
        retries=$((retries+1))
        if [[ ${retries} -gt 20 ]]; then
            warn "WireProxy ${name} failed to start (port :${socks_port} timeout after 10s)"
            kill "${pid}" 2>/dev/null || true
            return 1
        fi
        sleep 0.5
    done

    # Verify with curl
    local check_ip=""
    check_ip=$(timeout 8 curl -s --socks5 "127.0.0.1:${socks_port}" http://ifconfig.me 2>/dev/null || echo "")
    if [[ -n "${check_ip}" ]]; then
        ok "WireProxy ${name} ready on :${socks_port} → IP: ${check_ip}"
    else
        ok "WireProxy ${name} ready on :${socks_port} (IP check skipped)"
    fi
    return 0
}

stop_wireproxy() {
    local name="${1}"
    vlog "Stopping wireproxy: ${name}"
    pkill -f "wireproxy -c ${WIREPROXY_CONF_DIR}/${name}.conf" 2>/dev/null || true
}

stop_all_proxies() {
    log "Stopping all proxy instances..."

    # Kill wireproxy instances
    pkill -f "wireproxy -c ${WIREPROXY_CONF_DIR}" 2>/dev/null || true

    # Kill SSH SOCKS tunnels
    pkill -f "ssh.*-N.*-D" 2>/dev/null || true

    # Kill PIDs from pid file
    if [[ -f "${PID_FILE}" ]]; then
        while read -r pid; do
            kill "${pid}" 2>/dev/null || true
        done < "${PID_FILE}"
        rm -f "${PID_FILE}"
    fi

    # Kill rotator
    if [[ -f "${CONFIG_DIR}/rotator.pid" ]]; then
        kill "$(cat "${CONFIG_DIR}/rotator.pid")" 2>/dev/null || true
        rm -f "${CONFIG_DIR}/rotator.pid"
    fi

    # Kill health checker
    if [[ -f "${CONFIG_DIR}/healthcheck.pid" ]]; then
        kill "$(cat "${CONFIG_DIR}/healthcheck.pid")" 2>/dev/null || true
        rm -f "${CONFIG_DIR}/healthcheck.pid"
    fi

    ok "All proxies stopped"
}

wireproxy_status() {
    local running=0
    for wp_conf in "${WIREPROXY_CONF_DIR}"/*.conf; do
        [[ -f "${wp_conf}" ]] || continue
        local name
        name=$(basename "${wp_conf}" .conf)
        local socks_port
        socks_port=$(grep -A2 '\[Socks5\]' "${wp_conf}" | grep BindAddress | awk -F: '{print $NF}' || echo "?")

        if pkill -0 -f "wireproxy -c ${wp_conf}" 2>/dev/null; then
            local ip=""
            ip=$(timeout 3 curl -s --socks5 "127.0.0.1:${socks_port}" http://ifconfig.me 2>/dev/null || echo "?")
            echo -e "  ${GREEN}●${NC} ${name}  :${socks_port}  IP: ${ip}"
            running=$((running+1))
        else
            echo -e "  ${RED}○${NC} ${name}  :${socks_port}  (not running)"
        fi
    done
    echo ""
    echo "  WireProxy instances running: ${running}"
}

# ════════════════════════════════════════════════════════════════════════════════
# SECTION 5: SERVER DISCOVERY & HEALTH
# ════════════════════════════════════════════════════════════════════════════════

discover_servers() {
    log "Discovering VPN servers..."
    local total=0

    # Merge servers from all providers
    local merged='[]'

    # 1. Servers from config
    if [[ -f "${SERVERS_FILE}" ]]; then
        local count
        count=$(jq length "${SERVERS_FILE}" 2>/dev/null || echo 0)
        merged=$(jq '.' "${SERVERS_FILE}")
        total=$((total + count))
        vlog "Found ${count} servers from ${SERVERS_FILE}"
    fi

    # 2. Servers from provider plugins
    for provider_dir in "${PROVIDERS_DIR}"/*/; do
        [[ -d "${provider_dir}" ]] || continue
        local provider_name
        provider_name=$(basename "${provider_dir}")
        local provider_servers="${provider_dir}/servers.json"

        if [[ -f "${provider_servers}" ]]; then
            local pcount
            pcount=$(jq length "${provider_servers}" 2>/dev/null || echo 0)
            merged=$(jq --slurpfile new "${provider_servers}" '. + $new[0]' <(echo "${merged}"))
            total=$((total + pcount))
            vlog "Found ${pcount} servers from provider: ${provider_name}"
        fi
    done

    # 3. Oracle VMs as additional endpoints
    if [[ -f "${ORACLE_VMS_FILE}" ]]; then
        local vm_count
        vm_count=$(jq length "${ORACLE_VMS_FILE}" 2>/dev/null || echo 0)
        total=$((total + vm_count))
        vlog "Found ${vm_count} Oracle VM endpoints"
    fi

    echo "${merged}" > "${STATE_DIR}/all_servers.json"
    ok "Discovered ${total} total server endpoints"
}

health_check() {
    local socks_port="${1}"
    local timeout_sec="${2:-5}"

    # Check if port is open
    if ! (echo > /dev/tcp/127.0.0.1/${socks_port}) 2>/dev/null; then
        return 1
    fi

    # Try to reach internet through SOCKS5
    local ip=""
    ip=$(timeout "${timeout_sec}" curl -s --socks5 "127.0.0.1:${socks_port}" http://ifconfig.me 2>/dev/null || echo "")
    if [[ -n "${ip}" ]]; then
        echo "${ip}"
        return 0
    fi
    return 1
}

health_check_all() {
    log "Running health checks on all SOCKS5 proxies..."
    local healthy=0 total=0

    for socks_port in $(seq "${SOCKS_BASE_PORT}" "$((SOCKS_BASE_PORT + 50))"); do
        (echo > /dev/tcp/127.0.0.1/${socks_port}) 2>/dev/null || continue
        total=$((total+1))

        local ip
        ip=$(timeout 5 curl -s --socks5 "127.0.0.1:${socks_port}" http://ifconfig.me 2>/dev/null || echo "")
        if [[ -n "${ip}" ]]; then
            ok "Port ${socks_port} → IP: ${ip}"
            healthy=$((healthy+1))
        else
            warn "Port ${socks_port} — no response"
        fi
    done

    log "Health check: ${healthy}/${total} proxies healthy"
    echo "${healthy}" > "${STATE_DIR}/healthy_count"
    echo "${total}" > "${STATE_DIR}/total_count"
}

sort_by_latency() {
    log "Ping-sorting VPN servers by latency..."
    local results="[]"

    for socks_port in $(seq "${SOCKS_BASE_PORT}" "$((SOCKS_BASE_PORT + 50))"); do
        (echo > /dev/tcp/127.0.0.1/${socks_port}) 2>/dev/null || continue

        local start_ns end_ns latency_ms
        start_ns=$(date +%s%N)
        if timeout 8 curl -s --socks5 "127.0.0.1:${socks_port}" http://ifconfig.me >/dev/null 2>&1; then
            end_ns=$(date +%s%N)
            latency_ms=$(( (end_ns - start_ns) / 1000000 ))
        else
            latency_ms=9999
        fi

        results=$(echo "${results}" | jq --argjson p "${socks_port}" --argjson m "${latency_ms}" \
            '. + [{"port": $p, "latency_ms": $m}]')
    done

    echo "${results}" | jq 'sort_by(.latency_ms)' > "${STATE_DIR}/sorted_servers.json"
    ok "Servers sorted by latency (saved to ${STATE_DIR}/sorted_servers.json)"
    jq -r '.[] | "  Port \(.port): \(.latency_ms)ms"' "${STATE_DIR}/sorted_servers.json"
}

