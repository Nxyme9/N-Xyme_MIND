[Unit]
Description=Model Router Proxy Service
After=network.target

[Service]
Type=simple
User=nxyme
WorkingDirectory=/home/nxyme/N-Xyme_MIND
Environment=PYTHONPATH=/home/nxyme/N-Xyme_MIND
ExecStart=/usr/bin/python3 -m uvicorn src.proxy.model_router:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
