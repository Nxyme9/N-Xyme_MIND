{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "small_model": "opencode/minimax-m2.5-free",
  "instructions": [
    "AGENTS.md"
  ],
  "command": {
    "brain": {
      "template": "Execute brain CLI: $ARGUMENTS. Use scripts/brain-cli.py or scripts/brain",
      "description": "Execute brain CLI tool calling",
      "agent": "sisyphus"
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "enabled_providers": [
    "opencode",
    "openrouter",
    "anthropic",
    "google",
    "deepseek",
    "xai",
    "cohere",
    "ollama",
    "lmstudio",
    "gguf"
  ],
  "permission": {
    "external_directory": "allow",
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "*": "allow"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "rm -rf /*": "deny",
      "sudo *": "deny",
      "mkfs *": "deny",
      "dd *": "deny",
      "chmod 777 *": "deny",
      "curl * | *sh": "deny",
      "wget * | *sh": "deny"
    }
  },
  "agent": {
    "sisyphus": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "hephaestus": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "prometheus": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "atlas": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_to_cloud": true,
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "oracle": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "momus": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "metis": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "explore": {
      "model": "gguf/qwen2.5-coder-7b-q4_k_m",
      "router_override": {
        "prefer": "gguf/qwen2.5-coder-7b-q4_k_m",
        "fallback_order": []
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "skip_local": true,
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "sisyphus-junior": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_to_cloud": true,
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "multimodal-looker": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "skip_local": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "nx-mind": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "nx_mind_mcp"],
      "environment": { "PYTHONPATH": "." }
    },
    "unified-memory": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.memory_core.mcp_server"],
      "environment": { "PYTHONPATH": ".:src/infrastructure", "ROOT": "." }
    },
    "learning-engine": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.learning_engine.mcp_server"],
      "environment": { "PYTHONPATH": "." }
    },
    "intelligence": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.intelligence.mcp_server"],
      "environment": { "PYTHONPATH": "." }
    },
    "session-pool": {
      "type": "local",
      "command": ["python3", "-m", "mcp_server"],
      "environment": { "PYTHONPATH": "packages/session-pool-mcp" }
    },
    "quality-gates": {
      "type": "local",
      "command": ["./.venv/bin/quality-gates-mcp"],
      "environment": { "PYTHONPATH": "packages/quality-gates-mcp" }
    },
    "telegram": {
      "type": "local",
      "command": ["./.venv/bin/telegram-mcp-wrapper"],
      "environment": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}"
      }
    },
    "nx-context": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "nx_context_mcp"],
      "environment": { "PYTHONPATH": "packages/nx-context-mcp:." }
    },
    "trigger-guardian": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "trigger_guardian_mcp"],
      "environment": { "PYTHONPATH": "packages/trigger-guardian-mcp" }
    },
    "orchestration": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.orchestration.mcp_server"],
      "environment": { "PYTHONPATH": "." }
    },
    "catalyst": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "catalyst_mcp"],
      "environment": { "PYTHONPATH": "packages/catalyst-mcp:." }
    },
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server"],
      "environment": {
        "NOTION_TOKEN": "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"
      }
    },
    "obsidian": {
      "type": "local",
      "command": ["/home/nxyme/N-Xyme_CODE/N-Xyme_MIND/.venv/bin/python", "/home/nxyme/N-Xyme_CODE/N-Xyme_MIND/packages/obsidian_mcp_fixed.py"],
      "environment": {
        "OBSIDIAN_API_KEY": "a28142a995356e59b1b6d98687111414f6e4e95dbc5aa6d784b8749796b5c867",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27123",
        "OBSIDIAN_PROTOCOL": "http"
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@beautyfree/modelcontextprotocol-server-github"],
      "environment": {}
    }
  },
