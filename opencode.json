{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "small_model": "opencode/minimax-m2.5-free",
  "instructions": [
    "AGENTS.md"
  ],
  "command": {
    "brain": {
      "template": "Execute brain CLI: $ARGUMENTS. Use scripts/brain-cli.py or scripts/brain",
      "description": "Execute brain CLI tool calling",
      "agent": "sisyphus"
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "enabled_providers": [
    "opencode",
    "openrouter",
    "anthropic",
    "google",
    "deepseek",
    "xai",
    "cohere",
    "ollama"
  ],
  "permission": {
    "external_directory": "allow",
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "*": "allow"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "rm -rf /*": "deny",
      "sudo *": "deny",
      "mkfs *": "deny",
      "dd *": "deny",
      "chmod 777 *": "deny",
      "curl * | *sh": "deny",
      "wget * | *sh": "deny"
    }
  },
  "agent": {
    "sisyphus": {
      "model": "opencode/qwen3.6-plus-free",
      "router_override": {
        "prefer": "opencode/qwen3.6-plus-free",
        "fallback_order": [
          "opencode/mimo-v2-pro-free",
          "opencode/minimax-m2.5-free"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "hephaestus": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_to_cloud": true,
        "fallback_order": [
          "ollama/qwen2.5-coder:7b"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "prometheus": {
      "model": "opencode/mimo-v2-pro-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-pro-free",
        "fallback_order": [
          "opencode/minimax-m2.5-free"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "atlas": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": [
          "ollama/qwen2.5-coder:7b"
        ]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "oracle": {
      "model": "opencode/mimo-v2-pro-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-pro-free",
        "skip_local": true,
        "fallback_order": [
          "opencode/kimi-k2.5-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "momus": {
      "model": "opencode/kimi-k2.5-free",
      "router_override": {
        "prefer": "opencode/kimi-k2.5-free",
        "skip_local": true,
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "metis": {
      "model": "opencode/mimo-v2-pro-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-pro-free",
        "skip_local": true,
        "fallback_order": [
          "opencode/minimax-m2.5-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_to_cloud": true,
        "fallback_order": [
          "ollama/qwen2.5-coder:7b"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "skip_local": true,
        "fallback_order": [
          "opencode/mimo-v2-pro-free"
        ]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "sisyphus-junior": {
      "model": "ollama/llama3.2:3b",
      "router_override": {
        "prefer": "ollama/llama3.2:3b",
        "fallback_to_cloud": true,
        "fallback_order": [
          "opencode/minimax-m2.5-free"
        ]
      },
      "permission": {
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "multimodal-looker": {
      "model": "opencode/mimo-v2-omni-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-omni-free",
        "skip_local": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "nx-mind": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "nx_mind_mcp"],
      "environment": { "PYTHONPATH": "." }
    },
    "unified-memory": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.memory_core.mcp_server"],
      "environment": { "PYTHONPATH": ".:src/infrastructure", "ROOT": "." }
    },
    "learning-engine": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.learning_engine.mcp_server"],
      "environment": { "PYTHONPATH": "." }
    },
    "intelligence": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.intelligence.mcp_server"],
      "environment": { "PYTHONPATH": "." }
    },
    "quality-gates": {
      "type": "local",
      "command": ["./.venv/bin/quality-gates-mcp"],
      "environment": { "PYTHONPATH": "packages/quality-gates-mcp" }
    },
    "telegram": {
      "type": "local",
      "command": ["./.venv/bin/telegram-mcp-wrapper"],
      "environment": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}"
      }
    },
    "athena-context": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "athena_context_mcp"],
      "environment": { "PYTHONPATH": "." }
    },
    "trigger-guardian": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "trigger_guardian_mcp"],
      "environment": { "PYTHONPATH": "packages/trigger-guardian-mcp" }
    },
    "orchestration": {
      "type": "local",
      "command": ["./.venv/bin/python", "-m", "packages.orchestration.mcp_server"],
      "environment": { "PYTHONPATH": "." }
    },
    "obsidian": {
      "type": "local",
      "command": ["uvx", "mcp-obsidian"],
      "environment": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@beautyfree/modelcontextprotocol-server-github"],
      "environment": {}
    },
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "mimo-ai/mimo-v2-pro-free": {
          "name": "Mimo v2 Pro (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "minimax/minimax-m2.5:free": {
          "name": "MiniMax M2.5 (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "qwen/qwen3-coder:free": {
          "name": "Qwen 3 Coder (Free)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "deepseek/deepseek-r1:free": {
          "name": "DeepSeek R1 (Free)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "google": {
      "options": {
        "baseURL": "https://generativelanguage.googleapis.com/v1beta"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (local)"
        },
        "llama3.2:3b": {
          "name": "Llama 3.2 3B (local)"
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {}
    },
    "gguf": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GGUF Direct (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "qwen2.5-coder-7b-q4": {
          "name": "Qwen 2.5 Coder 7B Q4 (direct GGUF)"
        },
        "qwen2.5-0.5b-q4": {
          "name": "Qwen 2.5 0.5B Q4 (direct GGUF)"
        },
        "nomic-embed-text": {
          "name": "Nomic Embed Text (embedding)"
        }
      }
    },
    "opencode": {
      "options": {},
      "models": {
        "qwen3.6-plus-free": {
          "name": "Qwen 3.6 Plus (Free)",
          "limit": {
            "context": 1000000,
            "output": 8192
          }
        },
        "mimo-v2-pro-free": {
          "name": "Mimo v2 Pro (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "mimo-v2-omni-free": {
          "name": "Mimo v2 Omni (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "minimax-m2.5-free": {
          "name": "MiniMax M2.5 (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "kimi-k2.5-free": {
          "name": "Kimi K2.5 (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  }
}