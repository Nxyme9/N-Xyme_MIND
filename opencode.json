{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "small_model": "opencode/minimax-m2.5-free",
  "instructions": [
    "AGENTS.md"
  ],
  "command": {
    "brain": {
      "template": "Execute brain CLI: $ARGUMENTS. Use scripts/brain-cli.py or scripts/brain",
      "description": "Execute brain CLI tool calling",
      "agent": "sisyphus"
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "enabled_providers": [
    "opencode",
    "openrouter",
    "google",
    "ollama"
  ],
  "permission": {
    "external_directory": "allow",
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "*": "allow"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "rm -rf /*": "deny",
      "sudo *": "deny",
      "mkfs *": "deny",
      "dd *": "deny",
      "chmod 777 *": "deny",
      "curl * | *sh": "deny",
      "wget * | *sh": "deny"
    }
  },
  "agent": {
    "sisyphus": {
      "model": "opencode/qwen3.6-plus-free",
      "router_override": {
        "prefer": "opencode/qwen3.6-plus-free",
        "fallback_order": ["opencode/mimo-v2-pro-free", "opencode/minimax-m2.5-free"]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "hephaestus": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_to_cloud": true,
        "fallback_order": ["ollama/qwen2.5-coder:7b"]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "prometheus": {
      "model": "opencode/mimo-v2-pro-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-pro-free",
        "fallback_order": ["opencode/minimax-m2.5-free"]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "atlas": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_order": ["ollama/qwen2.5-coder:7b"]
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "oracle": {
      "model": "opencode/mimo-v2-pro-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-pro-free",
        "skip_local": true,
        "fallback_order": ["opencode/kimi-k2.5-free"]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "momus": {
      "model": "opencode/kimi-k2.5-free",
      "router_override": {
        "prefer": "opencode/kimi-k2.5-free",
        "skip_local": true,
        "fallback_order": ["opencode/mimo-v2-pro-free"]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "metis": {
      "model": "opencode/mimo-v2-pro-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-pro-free",
        "skip_local": true,
        "fallback_order": ["opencode/minimax-m2.5-free"]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "fallback_to_cloud": true,
        "fallback_order": ["ollama/qwen2.5-coder:7b"]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "router_override": {
        "prefer": "opencode/minimax-m2.5-free",
        "skip_local": true,
        "fallback_order": ["opencode/mimo-v2-pro-free"]
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "sisyphus-junior": {
      "model": "ollama/llama3.2:3b",
      "router_override": {
        "prefer": "ollama/llama3.2:3b",
        "fallback_to_cloud": true,
        "fallback_order": ["opencode/minimax-m2.5-free"]
      },
      "permission": {
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "multimodal-looker": {
      "model": "opencode/mimo-v2-omni-free",
      "router_override": {
        "prefer": "opencode/mimo-v2-omni-free",
        "skip_local": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-filesystem",
        "."
      ]
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-fetch-server"
      ]
    },
    "git": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-git"
      ]
    },
    "athena-context": {
      "type": "local",
      "command": [
        "./packages/athena-context-mcp/venv/bin/python",
        "-m",
        "athena_context_mcp"
      ]
    },
    "trigger-guardian": {
      "type": "local",
      "command": [
        "./packages/trigger-guardian-mcp/.venv/bin/python",
        "-m",
        "trigger_guardian_mcp"
      ]
    },
    "nx-mind": {
      "type": "local",
      "command": [
        "./packages/nx-mind-mcp/venv/bin/python",
        "-m",
        "nx_mind_mcp"
      ]
    },
    "athena": {
      "type": "local",
      "command": [
        "./venvs/athena/bin/python",
        "-m",
        "athena.mcp_server"
      ],
      "environment": {
        "PYTHONPATH": "./athena/src:."
      }
    },
    "github": {
      "type": "local",
      "command": [
        "./bin/github-mcp-server",
        "stdio",
        "--toolsets",
        "all"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "unified-memory": {
      "type": "local",
      "command": [
        "./venvs/athena/bin/python",
        "-m",
        "packages.memory_core.mcp_server"
      ],
      "environment": {
        "PYTHONPATH": ".:src/infrastructure",
        "ROOT": "."
      }
    },
    "intelligent-router": {
      "type": "local",
      "command": [
        "python3",
        "packages/infrastructure/proxy/simple_mcp_server.py"
      ],
      "environment": {
        "PYTHONPATH": "/home/nxyme/N-Xyme_CODE/N-Xyme_MIND:/home/nxyme/N-Xyme_CODE/N-Xyme_MIND/packages",
        "PATH": "/usr/bin:/bin"
      }
    },
    "learning-engine": {
      "type": "local",
      "command": [
        "./venvs/athena/bin/python",
        "-m",
        "packages.learning_engine.mcp_server"
      ],
      "environment": {
        "PYTHONPATH": "."
      }
    },
    "intelligence": {
      "type": "local",
      "command": [
        "./venvs/athena/bin/python",
        "-m",
        "packages.intelligence.mcp_server"
      ],
      "environment": {
        "PYTHONPATH": "."
      }
    },
    "orchestration": {
      "type": "local",
      "command": [
        "./venvs/athena/bin/python",
        "-m",
        "packages.orchestration.mcp_server"
      ],
      "environment": {
        "PYTHONPATH": "."
      }
    },
    "brain": {
      "type": "local",
      "command": [
        "python3",
        "-m",
        "scripts.brain_mcp"
      ]
    },
    "sqlite": {
      "type": "local",
      "command": [
        "python3",
        "-m",
        "sqlite_mcp"
      ],
      "environment": {
        "PYTHONPATH": "packages/sqlite-mcp"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ]
    },
    "quality-gates": {
      "type": "local",
      "command": [
        "python3",
        "-m",
        "quality_gates_mcp"
      ],
      "environment": {
        "PYTHONPATH": "packages/quality-gates-mcp"
      }
    },
    "telegram": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@benjapieres/mcp-telegram-listener"
      ],
      "environment": {
        "TELEGRAM_BOT_TOKEN": "8397949824:AAEkYzjVwIVUQAfTiFL2UcsGVC4Dgr7lXDw"
      }
    }
  },
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "mimo-ai/mimo-v2-pro-free": {
          "name": "Mimo v2 Pro (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "minimax/minimax-m2.5:free": {
          "name": "MiniMax M2.5 (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "qwen/qwen3-coder:free": {
          "name": "Qwen 3 Coder (Free)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "deepseek/deepseek-r1:free": {
          "name": "DeepSeek R1 (Free)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "google": {
      "options": {
        "baseURL": "https://generativelanguage.googleapis.com/v1beta"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (local)"
        },
        "llama3.2:3b": {
          "name": "Llama 3.2 3B (local)"
        }
      }
    },
    "opencode": {
      "options": {},
      "models": {
        "qwen3.6-plus-free": {
          "name": "Qwen 3.6 Plus (Free)",
          "limit": {
            "context": 1000000,
            "output": 8192
          }
        },
        "mimo-v2-pro-free": {
          "name": "Mimo v2 Pro (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "mimo-v2-omni-free": {
          "name": "Mimo v2 Omni (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "minimax-m2.5-free": {
          "name": "MiniMax M2.5 (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "kimi-k2.5-free": {
          "name": "Kimi K2.5 (Free)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  }
}